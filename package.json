{
  "name": "ai-skill-generator",
  "version": "1.0.0",
  "description": "Desktop application for managing AI coding skills and chatting with an AI agent",
  "author": "AI Skill Generator",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node scripts/generate-icons.mjs",
    "build": "electron-builder --win portable",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "build:all": "electron-builder --win portable --mac --linux",
    "pack": "electron-builder --win portable --dir"
  },
  "build": {
    "appId": "com.opencode.skill-generator",
    "productName": "AI Skill Generator",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "build/**/*"
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "portable": {
      "requestExecutionLevel": "user"
    },
    "mac": {
      "icon": "build/icon.png",
      "category": "public.app-category.developer-tools",
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "danitechIA",
      "repo": "AI-SKILL-CREATOR"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0"
  }
}
